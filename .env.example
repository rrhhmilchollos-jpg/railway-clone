# =============================================================
# creatuwebyappgratis.com — Panel de control (railway-clone)
# Copia este archivo a `.env` y rellena los valores reales.
# NUNCA subas el archivo `.env` real a GitHub.
# En producción (Coolify), configura estas variables en:
# Application -> Environment Variables
# =============================================================

# Puerto en el que escucha el servidor Node.js
PORT=5001
NODE_ENV=production

# Token de administración: protege /api/get-vars, /api/save-vars y /api/logs/*
# Genera uno con: openssl rand -hex 24
ADMIN_TOKEN=cambia_esto_por_un_token_largo_y_secreto

# Conexión a MongoDB (usa la URL interna del contenedor en Coolify)
MONGO_URL=mongodb://usuario:contraseña@mongodb:27017/creatuwebyapp?authSource=admin

# Conexión a Redis (usa la URL interna del contenedor en Coolify)
REDIS_URL=redis://default:contraseña@redis:6379/1

# URLs públicas del proyecto
APP_URL=https://creatuwebyappgratis.com
API_URL=https://creatuwebyappgratis.com
